# Local development database (zero setup).
# The npm dev/build/start scripts inject this SQLite value automatically, so you
# normally do not need a .env file for local development.
DATABASE_URL="file:./dev.db"

# Production database (Vercel/Supabase/Neon).
# IMPORTANT: prisma/schema.prisma reads env("DATABASE_URL"), so in production
# (e.g. Vercel) you MUST set DATABASE_URL to your PostgreSQL connection string.
# The value below is only a reference example to copy into DATABASE_URL.
POSTGRES_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketplace?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace-with-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Stripe test keys
STRIPE_SECRET_KEY="sk_test_replace"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace"
STRIPE_WEBHOOK_SECRET="whsec_replace"

# Optional local image upload path
UPLOAD_DIR="public/uploads"
