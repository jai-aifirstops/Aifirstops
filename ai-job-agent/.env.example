# AI Job Agent — environment variables
# Copy to .env and fill in values. Never commit secrets.

# Optional: Adzuna Job Search API (https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: SerpAPI for Google Jobs / LinkedIn search results
SERPAPI_API_KEY=

# Optional: Greenhouse / Lever API tokens if using private boards
GREENHOUSE_API_KEY=
LEVER_API_KEY=

# Agent behavior
DRY_RUN=true
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RATE_LIMIT_DELAY_SECONDS=1.0

# Candidate contact (optional overrides; prefer candidate_profile.yaml)
CANDIDATE_EMAIL=
CANDIDATE_PHONE=
